cp /dev/null .env.example
cat << 'EOF' > .env.example
# Citation Validator — API Keys
#
# Setup (one time):
#   cp .env.example .env
#   nano .env              # paste your keys
#
# Load (each terminal session):
#   source .env
#
# NEVER commit .env to git. It is already in .gitignore.

# Gemini (free tier: 1M tokens/day)
# Get key: https://aistudio.google.com/app/apikey
export GEMINI_API_KEY=

# Anthropic / Claude (paid — ~$0.50 per 100 citations)
# Get key: https://console.anthropic.com/settings/keys
export ANTHROPIC_API_KEY=

# OpenAI / GPT-4o (paid — ~$3.50 per 100 citations)
# Get key: https://platform.openai.com/api-keys
export OPENAI_API_KEY=

# Groq / Llama 3.3 (free tier with strict rate limits)
# Get key: https://console.groq.com/keys
export GROQ_API_KEY=
EOF

